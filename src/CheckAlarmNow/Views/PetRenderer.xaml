<UserControl x:Class="CheckAlarmNow.Views.PetRenderer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center">
        <!-- 상태 텍스트 (말풍선) -->
        <Border HorizontalAlignment="Center"
                Background="White" CornerRadius="8"
                Padding="8,4" Margin="0,0,0,4"
                BorderBrush="Gray" BorderThickness="1">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11" FontWeight="Bold"
                       TextAlignment="Center" Foreground="Black"/>
        </Border>

        <!-- 크기 증가 래퍼 -->
        <Grid x:Name="GrowWrapper" HorizontalAlignment="Center" Margin="0,0,0,4">
            <!-- 흔들림 + 이미지/오버레이 -->
            <Grid x:Name="PetBody" Width="120" Height="120">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ShakeTransform" X="0"/>
                </Grid.RenderTransform>

                <Image Source="{Binding PetImageSource}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                <Rectangle x:Name="ColorOverlay" Opacity="0">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{Binding PetImageSource}"
                                    Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </Grid>
    </StackPanel>
</UserControl>
